# Hugging Face 模型缓存目录（可选）
# 不设置时默认为「项目目录/huggingface」（与 run_download.bat / api_server 一致）
# 若需使用全局缓存（与 huggingface_hub 默认一致），例如：
# HF_HOME=C:\Users\<用户名>\.cache\huggingface

# 国内访问 huggingface.co 若 SSL 超时/断连，可取消下一行注释使用镜像（自行评估可用性）
# HF_ENDPOINT=https://hf-mirror.com

# HuggingFace Token（必需）
# 请访问 https://huggingface.co/settings/tokens 获取
HF_TOKEN=your-huggingface-token-here

# DeepSeek API Key（必需）
# 请访问 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# HTTP 端口（可选，默认 8000）。若被占用，启动时会自动尝试 8001、8002… 也可在此固定
# PORT=8001

# 是否在服务就绪后自动打开浏览器（可选，默认 1）。设为 0 则只打印控制台里的 URL
# OPEN_BROWSER=1

# 是否在模型已存在时跳过下载（可选，默认 false）
# 为 true 时仅使用本地缓存，不访问 Hub（需事先下载好权重）
# LOCAL_FILES_ONLY=false

# 是否允许在缓存缺失时从 Hugging Face 拉取（可选）
# 未设置时：与 LOCAL_FILES_ONLY 相反 —— LOCAL_FILES_ONLY=true 则不允许联网拉取
# ALLOW_HF_HUB_DOWNLOAD=true
